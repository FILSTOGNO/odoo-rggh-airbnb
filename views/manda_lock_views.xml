<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manda_lock_list" model="ir.ui.view">
        <field name="name">manda.lock.list</field>
        <field name="model">manda.lock</field>
        <field name="arch" type="xml">
            <list string="Serrures UniFi">
                <field name="name"/>
                <field name="door_location_id"/>
                <field name="access_policy_id"/>
                <field name="state" widget="badge" decoration-success="state == 'online'" decoration-danger="state == 'offline'"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>
    <record id="view_manda_lock_form" model="ir.ui.view">
        <field name="name">manda.lock.form</field>
        <field name="model">manda.lock</field>
        <field name="arch" type="xml">
            <form string="Serrure UniFi">
                <header>
                    <button name="action_test_connection" string="Tester connexion" type="object" class="btn-primary"/>
                    <button name="action_unlock_door" string="Déverrouiller" type="object" class="btn-warning"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Serrure Chambre 1..."/></h1>
                    </div>
                    <group>
                        <group string="Configuration UniFi">
                            <field name="door_location_id" placeholder="ID location UniFi..."/>
                            <field name="access_policy_id" placeholder="ID politique d'accès..."/>
                            <field name="last_sync" readonly="1"/>
                        </group>
                        <group string="Chambre associée">
                            <field name="room_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_manda_lock" model="ir.actions.act_window">
        <field name="name">Serrures UniFi</field>
        <field name="res_model">manda.lock</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
