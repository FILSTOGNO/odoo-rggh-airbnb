<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manda_room_list" model="ir.ui.view">
        <field name="name">manda.room.list</field>
        <field name="model">manda.room</field>
        <field name="arch" type="xml">
            <list string="Chambres">
                <field name="number"/>
                <field name="name"/>
                <field name="capacity"/>
                <field name="price_per_night"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'available'"
                    decoration-danger="state == 'occupied'"
                    decoration-warning="state == 'cleaning'"/>
                <field name="lock_id"/>
            </list>
        </field>
    </record>

    <record id="view_manda_room_form" model="ir.ui.view">
        <field name="name">manda.room.form</field>
        <field name="model">manda.room</field>
        <field name="arch" type="xml">
            <form string="Chambre">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_reservations" type="object"
                            class="oe_stat_button" icon="fa-calendar">
                            <field name="reservation_count" widget="statinfo" string="Réservations"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="number"/>
                            <field name="capacity"/>
                            <field name="price_per_night"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="lock_id"/>
                            <field name="beds24_room_id"/>
                            <field name="default_housekeeper_id"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description de la chambre..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_manda_room" model="ir.actions.act_window">
        <field name="name">Chambres</field>
        <field name="res_model">manda.room</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
