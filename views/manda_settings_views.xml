<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manda_settings_form" model="ir.ui.view">
        <field name="name">manda.settings.form</field>
        <field name="model">manda.settings</field>
        <field name="arch" type="xml">
            <form string="Configuration MandaBar">
                <sheet>
                    <div class="oe_title"><h1>Configuration MandaBar</h1></div>
                    <group string="🔐 UniFi Access API">
                        <group>
                            <field name="unifi_api_token" password="True" placeholder="Token API UniFi..."/>
                            <field name="unifi_hub_ip" placeholder="172.18.244.225"/>
                        </group>
                        <group>
                            <field name="unifi_switch_ip" placeholder="172.30.69.254"/>
                            <field name="unifi_switch2_ip" placeholder="172.30.69.80"/>
                        </group>
                    </group>
                    <group string="🏦 Compte Bancaire">
                        <group>
                            <field name="bank_account" placeholder="BE00 0000 0000 0000"/>
                            <field name="bank_bic" placeholder="GEBABEBB"/>
                        </group>
                        <group>
                            <field name="bank_name" placeholder="BNP Paribas Fortis"/>
                        </group>
                    </group>
                    <group string="📧 Email et PIN">
                        <group>
                            <field name="email_from" placeholder="noreply@fankepa.com"/>
                            <field name="pin_length"/>
                        </group>
                        <group>
                            <field name="auto_send_pin"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_manda_settings" model="ir.actions.act_window">
        <field name="name">Configuration</field>
        <field name="res_model">manda.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
